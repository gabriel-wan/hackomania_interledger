# Server
PORT=3000
NODE_ENV=development

# Open Payments
# Get these from https://wallet.interledger-test.dev after creating your fund wallet
OP_WALLET_ADDRESS=https://ilp.interledger-test.dev/master_wallet_address
OP_PRIVATE_KEY_PATH=./private.key
OP_KEY_ID=d67ba652-e7b3-4de4-950d-8798d9f6a2e1

# Database (ClickHouse)
# Run locally: docker run -d -p 8123:8123 -p 9000:9000 clickhouse/clickhouse-server
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=hackathon
CLICKHOUSE_DB=community_fund

# AI Verification (optional — set AI_ENABLED=true to activate)
AI_ENABLED=false
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1

# Disaster Signal Sources (defaults point to public APIs — no keys needed)
USGS_API_URL=https://earthquake.usgs.gov/fdsnws/event/1
WEATHER_API_URL=https://api.weather.gov
FLOOD_API_URL=

# Auth
JWT_SECRET=dev-secret-change-before-any-deployment

# Audit (optional — for publishing root hash to IPFS)
IPFS_API_URL=
IPFS_API_KEY=
